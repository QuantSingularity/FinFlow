# FinFlow Environment Variables
# Copy to .env and fill in real values — never commit .env

# Database passwords
AUTH_DB_PASSWORD=change_me_auth_db
PAYMENTS_DB_PASSWORD=change_me_payments_db
ACCOUNTING_DB_PASSWORD=change_me_accounting_db
ANALYTICS_DB_PASSWORD=change_me_analytics_db

# Application secrets
JWT_SECRET=change_me_jwt_secret_min_32_chars

# Payment provider
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Monitoring
GRAFANA_PASSWORD=change_me_grafana_admin

# Docker image tag (for compose)
TAG=local
