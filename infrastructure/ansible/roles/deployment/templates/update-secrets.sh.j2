#!/bin/bash
# Update Kubernetes secrets for FinFlow services
set -euo pipefail

NAMESPACE="{{ namespace | default('finflow-prod') }}"
SECRET_NAME="${1:-}"
KEY="${2:-}"
VALUE="${3:-}"

if [ -z "$SECRET_NAME" ] || [ -z "$KEY" ] || [ -z "$VALUE" ]; then
  echo "Usage: $0 <secret-name> <key> <value>"
  exit 1
fi

echo "Updating secret $SECRET_NAME/$KEY in namespace $NAMESPACE..."
kubectl patch secret "$SECRET_NAME" -n "$NAMESPACE" \
  --type='json' \
  -p="[{\"op\":\"replace\",\"path\":\"/data/${KEY}\",\"value\":\"$(echo -n "$VALUE" | base64 -w0)\"}]"
echo "Secret updated. Restart affected deployments to pick up the new value."
