# ============================================================
# FinFlow Backend - Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# --- Shared ---
NODE_ENV=development
LOG_LEVEL=info

# --- JWT ---
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://finflow:finflow_password@postgres:5432/finflow_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=finflow-service
KAFKA_GROUP_ID=finflow-group

# --- Auth Service ---
AUTH_SERVICE_PORT=4000

# --- Payments Service ---
PAYMENTS_SERVICE_PORT=4002
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Analytics Service ---
ANALYTICS_SERVICE_PORT=4004
TRANSACTION_HISTORY_MONTHS=12

# --- Accounting Service ---
ACCOUNTING_SERVICE_PORT=4003

# --- OAuth Providers (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth2/redirect/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Python Services ---
CREDIT_ENGINE_PORT=8000
TRANSACTION_SERVICE_PORT=8001
AI_FEATURES_PORT=8002
COMPLIANCE_SERVICE_PORT=8003
TAX_AUTOMATION_PORT=5000

# --- Audit Logging ---
AUDIT_LOG_PATH=/app/logs/audit.log
